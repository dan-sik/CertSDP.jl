{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certsdp.local/schemas/certsdp_certificate_v3.schema.json",
  "title": "CertSDP Certificate v3 Family Envelope",
  "oneOf": [
    { "$ref": "#/$defs/standard_psd_certificate" },
    { "$ref": "#/$defs/algebraic_low_rank_psd_certificate" },
    { "$ref": "#/$defs/block_native_algebraic_certificate" },
    { "$ref": "#/$defs/primal_dual_optimality_certificate" },
    { "$ref": "#/$defs/farkas_infeasibility_certificate" },
    { "$ref": "certsdp_sos_v3.schema.json" },
    { "$ref": "certsdp_nc_quantum_v3.schema.json" },
    { "$ref": "#/$defs/symmetry_reduction_certificate" }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "rational": {
      "type": "string",
      "pattern": "^-?[0-9]+(/[1-9][0-9]*)?$"
    },
    "proof_dag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_type", "nodes", "root_hash", "schema_version"],
      "properties": {
        "claim_type": {
          "enum": [
            "low_rank_psd",
            "chordal_psd",
            "algebraic_low_rank_psd",
            "block_native_algebraic",
            "primal_dual_optimality",
            "farkas_infeasibility",
            "sparse_sos",
            "quantum_bound",
            "symmetry_reduction"
          ]
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/proof_node" }
        },
        "root_hash": { "$ref": "#/$defs/sha256" },
        "schema_version": { "const": "3.0" }
      }
    },
    "proof_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "inputs", "output_hash", "checker", "status"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "inputs": { "type": "array", "items": { "type": "string" } },
        "output_hash": { "type": "string" },
        "checker": { "type": "string" },
        "status": { "const": "accepted" }
      }
    },
    "sparse_matrix": {
      "$ref": "certsdp_sparse_lmi_v3.schema.json#/$defs/sparse_matrix"
    },
    "low_rank_psd_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "matrix_hash",
        "factor",
        "diagonal",
        "identity_proof_hash"
      ],
      "properties": {
        "field": { "enum": ["QQ"] },
        "matrix_hash": { "$ref": "#/$defs/sha256" },
        "factor": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "$ref": "#/$defs/rational" }
          }
        },
        "diagonal": {
          "type": "array",
          "items": { "$ref": "#/$defs/rational" }
        },
        "identity_proof_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "standard_psd_certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certsdp_certificate_version",
        "certificate_type",
        "certificate_id",
        "problem_hash",
        "claim",
        "proof",
        "proof_dag",
        "metadata",
        "hash"
      ],
      "properties": {
        "certsdp_certificate_version": { "const": "3.0" },
        "certificate_type": {
          "enum": ["low_rank_psd_certificate", "chordal_psd_certificate"]
        },
        "certificate_id": { "$ref": "#/$defs/sha256" },
        "problem_hash": { "$ref": "#/$defs/sha256" },
        "claim": { "type": "object" },
        "proof": { "type": "object" },
        "proof_dag": { "$ref": "#/$defs/proof_dag" },
        "metadata": { "type": "object" },
        "hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "algebraic_field_certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_id",
        "generator",
        "minimal_polynomial",
        "isolating_interval",
        "field_hash"
      ],
      "properties": {
        "field_id": { "type": "string" },
        "generator": { "type": "string" },
        "minimal_polynomial": {
          "type": "array",
          "items": { "$ref": "#/$defs/rational" }
        },
        "isolating_interval": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/rational" }
        },
        "field_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "algebraic_element": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_hash", "coefficients", "element_hash"],
      "properties": {
        "field_hash": { "$ref": "#/$defs/sha256" },
        "coefficients": {
          "type": "array",
          "items": { "$ref": "#/$defs/rational" }
        },
        "element_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "algebraic_low_rank_psd_certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certsdp_algebraic_psd_factor_version",
        "matrix",
        "field",
        "factor",
        "diagonal",
        "identity_proof_hash",
        "proof_dag",
        "certificate_hash"
      ],
      "properties": {
        "certsdp_algebraic_psd_factor_version": { "const": "3.0" },
        "matrix": { "$ref": "#/$defs/sparse_matrix" },
        "field": { "$ref": "#/$defs/algebraic_field_certificate" },
        "factor": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "$ref": "#/$defs/algebraic_element" }
          }
        },
        "diagonal": {
          "type": "array",
          "items": { "$ref": "#/$defs/algebraic_element" }
        },
        "identity_proof_hash": { "$ref": "#/$defs/sha256" },
        "proof_dag": { "$ref": "#/$defs/proof_dag" },
        "certificate_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "block_native_algebraic_certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certsdp_block_native_certificate_version",
        "problem_hash",
        "incidence",
        "active_block_proofs",
        "inactive_psd_proofs",
        "proof_dag",
        "certificate_hash"
      ],
      "properties": {
        "certsdp_block_native_certificate_version": { "const": "3.0" },
        "problem_hash": { "$ref": "#/$defs/sha256" },
        "incidence": { "type": "object" },
        "active_block_proofs": { "type": "array" },
        "inactive_psd_proofs": { "type": "array" },
        "proof_dag": { "$ref": "#/$defs/proof_dag" },
        "certificate_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "primal_dual_optimality_certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certsdp_primal_dual_certificate_version",
        "problem_hash",
        "primal",
        "dual",
        "gap",
        "proof_dag",
        "certificate_hash"
      ],
      "properties": {
        "certsdp_primal_dual_certificate_version": { "const": "3.0" },
        "problem_hash": { "$ref": "#/$defs/sha256" },
        "primal": { "type": "object" },
        "dual": { "type": "object" },
        "gap": { "$ref": "#/$defs/rational" },
        "proof_dag": { "$ref": "#/$defs/proof_dag" },
        "certificate_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "farkas_infeasibility_certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certsdp_farkas_certificate_version",
        "problem_hash",
        "multiplier_identity_lhs",
        "multiplier_identity_rhs",
        "cone_proofs",
        "contradiction_lhs",
        "contradiction_rhs",
        "proof_dag",
        "certificate_hash"
      ],
      "properties": {
        "certsdp_farkas_certificate_version": { "const": "3.0" },
        "problem_hash": { "$ref": "#/$defs/sha256" },
        "multiplier_identity_lhs": {
          "type": "array",
          "items": { "$ref": "#/$defs/rational" }
        },
        "multiplier_identity_rhs": {
          "type": "array",
          "items": { "$ref": "#/$defs/rational" }
        },
        "cone_proofs": {
          "type": "array",
          "items": { "$ref": "#/$defs/low_rank_psd_proof" }
        },
        "contradiction_lhs": { "$ref": "#/$defs/rational" },
        "contradiction_rhs": { "$ref": "#/$defs/rational" },
        "proof_dag": { "$ref": "#/$defs/proof_dag" },
        "certificate_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "symmetry_reduction_certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certsdp_symmetry_certificate_version",
        "problem_hash",
        "group",
        "orbit_basis",
        "projection_blocks",
        "original_matrix",
        "reconstructed_matrix",
        "proof_dag",
        "certificate_hash"
      ],
      "properties": {
        "certsdp_symmetry_certificate_version": { "const": "3.0" },
        "problem_hash": { "$ref": "#/$defs/sha256" },
        "group": { "type": "object" },
        "orbit_basis": { "type": "object" },
        "projection_blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/sparse_matrix" }
        },
        "original_matrix": { "$ref": "#/$defs/sparse_matrix" },
        "reconstructed_matrix": { "$ref": "#/$defs/sparse_matrix" },
        "proof_dag": { "$ref": "#/$defs/proof_dag" },
        "certificate_hash": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
